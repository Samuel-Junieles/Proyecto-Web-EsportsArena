@{
    ViewData["Title"] = "Dashboard Arena";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container-fluid animate__animated animate__fadeIn">
    <div class="row mb-5">
        <div class="col-12 neu-card p-4">
            <h1 class="display-5 fw-bold text-white">
                BIENVENIDO, <span style="color: var(--accent-cyan)">@Context.Session.GetString("UsuarioLogueado")</span>
            </h1>
            <p style="color: #cbd5e0; font-size: 1.1rem; letter-spacing: 2px;">PANEL DE CONTROL / OPERACIONES ARENA</p>
        </div>
    </div>

    <div class="row mb-4 animate__animated animate__fadeInUp">
        <div class="col-md-4 mb-4">
            <div class="neu-card text-center p-4 h-100">
                <div class="icon-circle mx-auto mb-3">
                    <i class="bi bi-shield-shaded fs-2" style="color: var(--accent-cyan)"></i>
                </div>
                <h6 class="fw-bold" style="color: #a0aec0; letter-spacing: 1px;">MIS EQUIPOS</h6>
                <h2 class="display-5 fw-bold text-white">@ViewBag.MisEquipos</h2>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="neu-card text-center p-4 h-100">
                <div class="icon-circle mx-auto mb-3">
                    <i class="bi bi-check-circle-fill fs-2" style="color: #2ecc71"></i>
                </div>
                <h6 class="fw-bold" style="color: #a0aec0; letter-spacing: 1px;">PARTIDOS JUGADOS</h6>
                <h2 class="display-5 fw-bold text-white">@ViewBag.PartidosJugados</h2>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="neu-card text-center p-4 h-100">
                <div class="icon-circle mx-auto mb-3">
                    <i class="bi bi-clock-history fs-2" style="color: #ffcc00"></i>
                </div>
                <h6 class="fw-bold" style="color: #a0aec0; letter-spacing: 1px;">POR JUGAR</h6>
                <h2 class="display-5 fw-bold text-white">@ViewBag.PartidosPendientes</h2>
            </div>
        </div>
    </div>

    <div class="row mb-5">
    </div>

    <div class="row g-4">
        <div class="col-lg-8 animate__animated animate__fadeInUp animate__delay-1s">
            <div class="neu-card p-4 h-100">
                <h5 class="text-white mb-4">RENDIMIENTO ANALÍTICO</h5>
                <div class="chart-container" style="position: relative; height:320px; width:100%">
                    <canvas id="arenaChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4 animate__animated animate__fadeInUp animate__delay-1s">
            <div class="neu-card p-4 h-100">
                <h5 class="text-white mb-4">ESTADÍSTICAS GLOBALES</h5>
                <div class="chart-container" style="position: relative; height:320px; width:100%">
                    <canvas id="distribucionChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/dashboard-charts.js" asp-append-version="true"></script>
}