@{
    ViewData["Title"] = "Dashboard Arena";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="text-primary fw-bold">BIENVENIDO A LA ARENA, @Context.Session.GetString("UsuarioLogueado")</h1>
            <p class="text-muted">Gestiona tus equipos, torneos y resultados desde este panel.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card bg-dark text-white border-primary mb-3 shadow-lg">
                <div class="card-body">
                    <h5 class="card-title text-info">Mis Equipos</h5>
                    <p class="card-text display-6">0</p>
                    <a asp-controller="Equipos" asp-action="Index" class="btn btn-outline-info btn-sm">Ver detalles</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white border-success mb-3 shadow-lg">
                <div class="card-body">
                    <h5 class="card-title text-success">Torneos Activos</h5>
                    <p class="card-text display-6">0</p>
                    <a asp-controller="Torneos" asp-action="Index" class="btn btn-outline-success btn-sm">Ir a Torneos</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white border-warning mb-3 shadow-lg">
                <div class="card-body">
                    <h5 class="card-title text-warning">Próximos Encuentros</h5>
                    <p class="card-text display-6">0</p>
                    <a asp-controller="Encuentros" asp-action="Index" class="btn btn-outline-warning btn-sm">Ver Calendario</a>
                </div>
            </div>
        </div>
    </div>
</div>