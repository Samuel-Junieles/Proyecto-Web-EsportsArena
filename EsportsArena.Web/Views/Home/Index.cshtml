<div class="p-5 mb-5 rounded-3 position-relative overflow-hidden"
     style="background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1542751371-adc38448a05e?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80'); background-size: cover; background-position: center;">
    <div class="container-fluid py-5 text-center">
        <h1 class="display-4 fw-bold text-white">Dashboard General</h1>
        <p class="fs-4 text-light">Gestión integral de la Arena de eSports</p>
    </div>
</div>

<div class="row text-center g-4 mb-5">
    <div class="col-md-3">
        <div class="stat-card p-4">
            <h5>Equipos</h5>
            <div class="stat-number">150</div>
            <button class="btn btn-primary btn-sm mt-2">Ver Todos</button>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card p-4">
            <h5>Torneos</h5>
            <div class="stat-number">12</div>
            <button class="btn btn-primary btn-sm mt-2">Ver Activos</button>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card p-4">
            <h5>Premios</h5>
            <div class="stat-number">$5k</div>
            <button class="btn btn-primary btn-sm mt-2">Detalles</button>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card p-4">
            <h5>Próximo Evento</h5>
            <p class="text-info mt-3 fw-bold">VALORANT MASTERS</p>
            <div class="small text-muted">20/10/2026</div>
        </div>
    </div>
</div>

<div class="card p-4 bg-dark shadow-lg">
    <h3 class="mb-4 text-primary">Resultados Recientes <small class="text-muted fs-6">(Trazabilidad)</small></h3>
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle">
            <thead class="table-primary text-dark">
                <tr>
                    <th>Torneo</th>
                    <th>Equipo 1</th>
                    <th>Equipo 2</th>
                    <th>Puntaje</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>LoL Masters</td>
                    <td>Dragons PC</td>
                    <td>Wolves Gaming</td>
                    <td class="fw-bold text-info">2 - 1</td>
                    <td><span class="badge bg-success">Finalizado</span></td>
                </tr>
                <tr>
                    <td>Squad Fire Cup</td>
                    <td>Los Pibes</td>
                    <td>Team Mobile</td>
                    <td class="fw-bold text-info">90 Kills</td>
                    <td><span class="badge bg-warning text-dark">En Curso</span></td>
                </tr>
                <tr>
                    <td>Free Fire Pro</td>
                    <td>BO3</td>
                    <td>Don Kings</td>
                    <td class="fw-bold text-info">0 - 0</td>
                    <td><span class="badge bg-secondary">Pendiente</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
