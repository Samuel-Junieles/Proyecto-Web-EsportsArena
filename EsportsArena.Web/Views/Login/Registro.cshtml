@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registro Arena - Esports Arena</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('https://wallpaperaccess.com/full/2404179.jpg');
            background-size: cover;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .reg-card {
            background: rgba(22, 27, 34, 0.9);
            border: 1px solid #58a6ff;
            border-radius: 15px;
            padding: 35px;
            width: 100%;
            max-width: 450px;
            color: white;
        }

        .form-control {
            background: #0d1117;
            border: 1px solid #30363d;
            color: white;
        }
    </style>
</head>
<body>
    <div class="reg-card">
        <h2 class="text-center mb-4 fw-bold text-primary">NUEVO USUARIO</h2>
        <form asp-controller="Login" asp-action="Registrar" method="post">
            <div class="mb-3">
                <label class="small text-muted">NOMBRE DE USUARIO</label>
                <input type="text" name="Username" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="small text-muted">EMAIL</label>
                <input type="email" name="Email" class="form-control" required />
            </div>
            <div class="mb-4">
                <label class="small text-muted">CONTRASEÑA</label>
                <input type="password" name="password" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100 fw-bold">CREAR CUENTA</button>
            <div class="mt-3 text-center">
                <a asp-action="Index" class="text-white-50 small">Volver al ingreso</a>
            </div>
        </form>
    </div>
</body>
</html>