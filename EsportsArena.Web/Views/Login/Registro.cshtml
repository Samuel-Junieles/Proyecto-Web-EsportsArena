@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro Arena - Esports Arena</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --bg-card: rgba(22, 26, 30, 0.7);
            --shadow-dark: #000000;
            --shadow-light: rgba(255, 255, 255, 0.05);
            --accent-cyan: #00f2fe;
            --accent-purple: #7000ff;
            --text-main: #e0e6ed;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            overflow: hidden;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        #video-background {
            position: fixed;
            right: 0;
            bottom: 0;
            min-width: 100%;
            min-height: 100%;
            z-index: -2;
            filter: blur(6px) brightness(0.5); 
            object-fit: cover;
        }

        .video-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: -1;
        }

        .reg-container {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 1;
        }

        .reg-card {
            background: var(--bg-card);
            backdrop-filter: blur(15px);
            padding: 2.5rem;
            width: 90%;
            max-width: 450px;
            border-radius: 40px;
            box-shadow: 20px 20px 60px var(--shadow-dark), -5px -5px 30px var(--shadow-light);
            border: 1px solid rgba(255, 255, 255, 0.1);
            text-align: center;
        }

        .gamer-title {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 3px;
            background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 2rem;
            text-transform: uppercase;
        }

        .form-control {
            background: rgba(10, 10, 10, 0.5);
            border: none;
            border-radius: 12px;
            padding: 12px;
            color: white !important;
            box-shadow: inset 4px 4px 8px #000;
            transition: 0.3s;
        }

            .form-control:focus {
                background: rgba(10, 10, 10, 0.7);
                box-shadow: inset 2px 2px 4px #000;
                outline: 1px solid var(--accent-cyan);
            }

        .btn-gamer {
            margin-top: 1rem;
            background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
            border: none;
            border-radius: 12px;
            color: #fff;
            font-weight: 800;
            padding: 14px;
            width: 100%;
            transition: 0.2s;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(0, 242, 254, 0.3);
        }

            .btn-gamer:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(0, 242, 254, 0.5);
                filter: brightness(1.1);
            }

            .btn-gamer:active {
                transform: translateY(0);
            }

        .form-label-custom {
            color: #8b949e;
            font-size: 0.75rem;
            font-weight: 700;
            margin-bottom: 6px;
            display: block;
            text-align: left;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .link-back {
            color: #8b949e;
            transition: 0.3s;
            text-decoration: none;
        }

            .link-back:hover {
                color: var(--accent-cyan);
                text-shadow: 0 0 8px var(--accent-cyan);
            }
    </style>
</head>
<body>

    <video autoplay muted loop id="video-background">
        <source src="/Videos/FondoInicio.mp4" type="video/mp4">
    </video>

    <div class="video-overlay"></div>

    <div class="reg-container">
        <div class="reg-card">
            <h2 class="gamer-title">NUEVO USUARIO</h2>

            <form asp-controller="Login" asp-action="Registrar" method="post">
                <div class="mb-3">
                    <label class="form-label-custom">NOMBRE DE USUARIO</label>
                    <input type="text" name="Username" class="form-control" placeholder="Ej: PlayerOne" required />
                </div>

                <div class="mb-3">
                    <label class="form-label-custom">CORREO ELECTRÓNICO</label>
                    <input type="email" name="Email" class="form-control" placeholder="correo@ejemplo.com" required />
                </div>

                <div class="mb-4">
                    <label class="form-label-custom">CONTRASEÑA</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                </div>

                <button type="submit" class="btn btn-gamer">CREAR CUENTA</button>

                <div class="mt-4">
                    <a asp-action="Index" class="link-back small">
                        <i class="bi bi-arrow-left"></i> VOLVER AL INGRESO
                    </a>
                </div>
            </form>
        </div>
    </div>

    <input type="hidden" id="loginErrorData" value="@TempData["LoginError"]" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/SweetAlert2.js" asp-append-version="true"></script>

</body>
</html>