@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ingreso Arena - Esports Arena</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <style>
        :root {
            --bg-card: rgba(22, 26, 30, 0.7); 
            --shadow-dark: #000000;
            --shadow-light: rgba(255, 255, 255, 0.05);
            --accent-cyan: #00f2fe;
            --text-main: #e0e6ed;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            overflow: hidden; 
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        #video-background {
            position: fixed;
            right: 0;
            bottom: 0;
            min-width: 100%;
            min-height: 100%;
            z-index: -2;
            filter: blur(4px) brightness(0.6); 
            object-fit: cover;
        }

        .video-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: -1;
        }

        .login-container {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 1;
        }

        .login-card {
            background: var(--bg-card);
            backdrop-filter: blur(15px); 
            padding: 3rem;
            width: 90%;
            max-width: 400px;
            border-radius: 40px;
            box-shadow: 20px 20px 60px var(--shadow-dark), -5px -5px 30px var(--shadow-light);
            border: 1px solid rgba(255, 255, 255, 0.1);
            text-align: center;
        }

        .gamer-title {
            font-size: 1.6rem;
            font-weight: 800;
            letter-spacing: 4px;
            background: linear-gradient(135deg, var(--accent-cyan), #7000ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 2.5rem;
        }

        .form-control {
            background: rgba(10, 10, 10, 0.5);
            border: none;
            border-radius: 15px;
            padding: 14px;
            color: white !important;
            box-shadow: inset 4px 4px 8px #000;
            transition: 0.3s;
        }

            .form-control:focus {
                background: rgba(10, 10, 10, 0.7);
                box-shadow: inset 2px 2px 4px #000;
                outline: 1px solid var(--accent-cyan);
            }

        .btn-gamer {
            margin-top: 1.5rem;
            background: var(--accent-cyan);
            border: none;
            border-radius: 15px;
            color: #000;
            font-weight: 800;
            padding: 15px;
            width: 100%;
            transition: 0.2s;
            text-transform: uppercase;
            box-shadow: 0 0 20px rgba(0, 242, 254, 0.4);
        }

            .btn-gamer:hover {
                transform: scale(1.02);
                background: #fff;
                box-shadow: 0 0 30px var(--accent-cyan);
            }

        .form-label-custom {
            color: #aaa;
            font-size: 0.75rem;
            font-weight: 700;
            margin-bottom: 8px;
            display: block;
            text-align: left;
        }
    </style>
</head>
<body>

    <video autoplay muted loop id="video-background">
        <source src="/Videos/FondoInicio.mp4" type="video/mp4">
        Tu navegador no soporta videos.
    </video>

    <div class="video-overlay"></div>

    <div class="login-container">
        <div class="login-card">
            <h2 class="gamer-title">INGRESO ARENA</h2>

            <form asp-controller="Login" asp-action="Ingresar" method="post">
                <div class="mb-4 text-start">
                    <label class="form-label-custom">Usuario</label>
                    <input type="text" name="username" class="form-control" placeholder="Usuario" required />
                </div>
                <div class="mb-4 text-start">
                    <label class="form-label-custom">Contraseña</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                </div>

                <input type="hidden" id="loginErrorData" value="@TempData["LoginError"]" />

                <button type="submit" class="btn btn-gamer">ENTRAR</button>

                <a asp-action="Registro" class="text-white-50 small d-block mt-4 text-decoration-none">
                    ¿No tienes cuenta? <span style="color: var(--accent-cyan)">Regístrate</span>
                </a>
            </form>
        </div>
    </div>

    <input type="hidden" id="registroSuccessData" value="@TempData["RegistroExitoso"]" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/SweetAlert.js" asp-append-version="true"></script>
    <script src="~/js/SweetAlert2.js" asp-append-version="true"></script>
</body>
</html>