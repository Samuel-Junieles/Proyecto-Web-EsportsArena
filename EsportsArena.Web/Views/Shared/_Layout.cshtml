<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eSports Arena</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --sidebar-bg: #0b0e14;
            --main-bg: #12171e;
            --accent: #007bff;
        }

        body {
            display: flex;
            min-height: 100vh;
            background-color: var(--main-bg);
            color: white;
            margin: 0;
            overflow-x: hidden;
        }

        /* Sidebar Lateral Izquierdo */
        #sidebar {
            width: 280px;
            background-color: var(--sidebar-bg);
            border-right: 1px solid #2d333b;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            transition: all 0.3s;
        }

        /* Contenido Principal */
        #main-wrapper {
            flex-grow: 1;
            margin-left: 280px;
            padding: 20px;
            width: calc(100% - 280px);
        }

        .nav-link {
            color: #8b949e;
            font-size: 0.95rem;
            padding: 12px 20px;
            border-radius: 8px;
            margin: 4px 10px;
            transition: 0.2s;
        }

            .nav-link:hover {
                color: white;
                background: rgba(255,255,255,0.05);
            }

            .nav-link.active {
                color: white;
                background: var(--accent);
                font-weight: bold;
            }

            .nav-link i {
                margin-right: 10px;
            }
    </style>
</head>
<body>

    <nav id="sidebar">
        <div class="p-4">
            <h4 class="text-primary fw-bold"><i class="bi bi-controller"></i> ARENA MANAGER</h4>
        </div>

        <div class="flex-column nav nav-pills">
            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a>
            <a class="nav-link" asp-controller="Usuarios" asp-action="Index"><i class="bi bi-people"></i> Usuarios</a>
            <a class="nav-link" asp-controller="Equipos" asp-action="Index"><i class="bi bi-shield-shaded"></i> Equipos</a>
            <a class="nav-link" asp-controller="Encuentros" asp-action="Index"><i class="bi bi-controller"></i> Encuentros</a>
            <a class="nav-link" asp-controller="Torneos" asp-action="Index"><i class="bi bi-trophy"></i> Torneos</a>
            <a class="nav-link" asp-controller="Reportes" asp-action="Index"><i class="bi bi-file-earmark-pdf"></i> Reportes</a>
        </div>

        <div class="mt-auto p-3 border-top border-secondary">
            <div class="d-flex align-items-center">
                <div class="ms-2">
                    <p class="mb-0 small text-muted">Sesión iniciada:</p>
                    <strong class="text-info">@Context.Session.GetString("UsuarioLogueado")</strong>
                </div>
            </div>
            <a asp-controller="Login" asp-action="Salir" class="btn btn-outline-danger btn-sm w-100 mt-2">Cerrar Sesión</a>
        </div>
    </nav>

    <div id="main-wrapper">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>