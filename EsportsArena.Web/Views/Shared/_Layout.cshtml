<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>eSports Arena Manager</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --primary-glow: #007bff;
            --secondary-glow: #6610f2;
            --dark-bg: #0b0e14;
            --card-bg: rgba(255, 255, 255, 0.05);
        }

        body {
            background-color: var(--dark-bg);
            color: #e0e0e0;
            font-family: 'Roboto', sans-serif;
        }

        h1, h2, h3, .navbar-brand {
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .navbar {
            background: rgba(11, 14, 20, 0.8) !important;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 123, 255, 0.3);
            padding: 1rem 0;
        }

        .navbar-brand {
            color: var(--primary-glow) !important;
            text-shadow: 0 0 10px rgba(0, 123, 255, 0.5);
        }

        .stat-card {
            background: var(--card-bg);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            transition: transform 0.3s ease, border-color 0.3s ease;
            backdrop-filter: blur(5px);
        }

            .stat-card:hover {
                transform: translateY(-10px);
                border-color: var(--primary-glow);
                box-shadow: 0 10px 30px rgba(0, 123, 255, 0.2);
            }

        .stat-number {
            font-size: 3rem;
            font-weight: bold;
            color: var(--primary-glow);
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" href="#">eSports Arena</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link active" href="#">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Equipos</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Torneos</a></li>
                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-outline-primary shadow-sm" href="#">LOGIN</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
