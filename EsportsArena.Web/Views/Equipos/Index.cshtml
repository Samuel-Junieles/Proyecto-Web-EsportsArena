@model IEnumerable<EsportsArena.Entities.Models.Equipo>

<div class="container-fluid animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold mb-0">MIS EQUIPOS</h2>
            <p class="text-muted">Gestiona tus squads inscritos en la arena.</p>
        </div>
        <a asp-action="Registrar" class="btn btn-primary fw-bold shadow-lg">
            <i class="bi bi-plus-circle-fill"></i> NUEVA INSCRIPCIÓN
        </a>
    </div>

    <div class="card bg-dark border-0 shadow-lg" style="background-color: #161b22 !important;">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead class="bg-black">
                    <tr>
                        <th class="ps-4">LOGO</th>
                        <th>NOMBRE DEL EQUIPO</th>
                        <th>JUEGO</th>
                        <th class="text-center">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var equipo in Model)
                    {
                        <tr style="vertical-align: middle;">
                            <td class="ps-4">
                                <img src="/Images/LogoDefault.png"
                                     alt="Logo"
                                     style="width: 50px; height: 50px; object-fit: cover; border-radius: 50%; border: 2px solid #00d4ff;">
                            </td>
                            <td class="fw-bold">@equipo.NombreEquipo</td>
                            <td><span class="badge bg-info-subtle text-info border border-info">@equipo.JuegoPrincipal</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted italic">
                                <i class="bi bi-exclamation-circle"></i> Aún no tienes equipos. ¡Crea el primero!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>