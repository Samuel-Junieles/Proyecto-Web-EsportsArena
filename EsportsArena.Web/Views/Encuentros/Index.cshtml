@model IEnumerable<EsportsArena.Entities.Models.Encuentro>
@{
    ViewData["Title"] = "Arena Live";
    var listaEquipos = ViewBag.Equipos as List<EsportsArena.Entities.Models.Equipo> ?? new List<EsportsArena.Entities.Models.Equipo>();
}

<div class="container-fluid animate__animated animate__fadeIn">
    <div class="row mb-5 align-items-center">
        <div class="col-md-8">
            <h2 class="display-6 fw-bold text-white mb-0">PRÓXIMOS <span style="color: var(--accent-cyan)">DUELOS</span></h2>
            <p style="color: #a0aec0; letter-spacing: 2px;">CARTELERA OFICIAL DE LA ARENA</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a asp-action="Registrar" class="btn btn-neu text-info fw-bold py-2 px-4">
                <i class="bi bi-swords me-2"></i>NUEVO DUELO
            </a>
        </div>
    </div>

    <div class="row">
        @foreach (var encuentro in Model)
        {
            var e1 = listaEquipos.FirstOrDefault(e => e.Id == encuentro.Equipo1Id);
            var e2 = listaEquipos.FirstOrDefault(e => e.Id == encuentro.Equipo2Id);

            <div class="col-xl-6 mb-4">
                <div class="vs-card">
                    <div class="team-side left-side">
                        <div class="team-avatar-wrapper">
                            <img src="@(string.IsNullOrEmpty(e1?.Logo) ? "/Images/LogoDefault.png" : e1.Logo)" alt="Logo 1">
                        </div>
                        <h4 class="team-name">@(e1?.NombreEquipo ?? "TBD")</h4>
                        <span class="team-tag">HOME</span>
                    </div>

                    <div class="vs-divider">
                        <div class="vs-glow">VS</div>
                        <div class="match-info">
                            <div class="match-date">
                                <i class="bi bi-calendar3"></i> @encuentro.FechaEncuentro.ToString("dd MMM")
                            </div>
                            <div class="match-time">@encuentro.FechaEncuentro.ToString("HH:mm")</div>
                            <div class="status-pill @(encuentro.Estado?.ToLower() == "pendiente" ? "pending" : "completed")">
                                @(encuentro.Estado ?? "PENDIENTE")
                            </div>
                        </div>
                    </div>

                    <div class="team-side right-side">
                        <div class="team-avatar-wrapper">
                            <img src="@(string.IsNullOrEmpty(e2?.Logo) ? "/Images/LogoDefault.png" : e2.Logo)" alt="Logo 2">
                        </div>
                        <h4 class="team-name">@(e2?.NombreEquipo ?? "TBD")</h4>
                        <span class="team-tag">AWAY</span>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="neu-card d-inline-block p-5">
                    <i class="bi bi-cpu-fill display-1 text-muted opacity-25"></i>
                    <p class="text-muted mt-3 fw-bold">NO HAY TRANSMISIONES PROGRAMADAS</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Estructura de la Tarjeta Versus */
    .vs-card {
        background: var(--bg-main);
        border-radius: 20px;
        padding: 30px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 10px 10px 20px #090c10, -5px -5px 15px #1b222c;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: transform 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .vs-card:hover {
            transform: translateY(-5px);
            border-color: rgba(0, 242, 254, 0.2);
        }

    /* Lados de los Equipos */
    .team-side {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        z-index: 2;
    }

    .team-avatar-wrapper {
        width: 100px;
        height: 100px;
        background: #0d1117;
        border-radius: 50%;
        padding: 5px;
        box-shadow: inset 4px 4px 8px #05070a, inset -2px -2px 8px #161b22;
        margin-bottom: 15px;
        border: 2px solid transparent;
        transition: 0.3s;
    }

    .vs-card:hover .team-avatar-wrapper {
        border-color: var(--accent-cyan);
    }

    .team-avatar-wrapper img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
    }

    .team-name {
        color: white;
        font-weight: 800;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0;
    }

    .team-tag {
        font-size: 0.65rem;
        color: var(--accent-cyan);
        font-weight: bold;
        opacity: 0.7;
    }

    /* Divisor VS Central */
    .vs-divider {
        flex: 0 0 140px;
        text-align: center;
        z-index: 2;
    }

    .vs-glow {
        font-size: 2.5rem;
        font-weight: 900;
        color: #f25c54; /* Rojo vibrante */
        text-shadow: 0 0 15px rgba(242, 92, 84, 0.5);
        font-style: italic;
        line-height: 1;
        margin-bottom: 10px;
    }

    .match-info {
        background: rgba(0,0,0,0.3);
        padding: 10px;
        border-radius: 12px;
        box-shadow: inset 2px 2px 5px #000;
    }

    .match-date {
        font-size: 0.75rem;
        color: #cbd5e0;
        font-weight: bold;
    }

    .match-time {
        font-size: 1.2rem;
        color: white;
        font-weight: 800;
        margin: 2px 0;
    }

    .status-pill {
        font-size: 0.6rem;
        font-weight: 900;
        padding: 3px 8px;
        border-radius: 5px;
        display: inline-block;
        letter-spacing: 1px;
    }

        .status-pill.pending {
            background: #4a5568;
            color: white;
        }

        .status-pill.completed {
            background: var(--accent-cyan);
            color: #000;
        }

    /* Fondo decorativo sutil */
    .vs-card::before {
        content: "BATTLE";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 6rem;
        font-weight: 900;
        color: rgba(255, 255, 255, 0.02);
        z-index: 1;
    }
</style>