@model List<EsportsArena.Entities.Models.Equipo>

<div class="container mt-5">
    <div class="card bg-dark text-white border-warning">
        <div class="card-header border-warning text-center">
            <h3 class="text-warning fw-bold">CONFIGURAR BATALLA</h3>
        </div>
        <div class="card-body">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <form asp-action="GuardarEncuentro" method="post">
                <div class="row text-center align-items-center">
                    <div class="col-md-5">
                        <label class="text-info small fw-bold">LOCAL</label>
                        <select name="Equipo1Id" class="form-select bg-black text-white border-secondary">
                            @foreach (var eq in Model)
                            {
                                <option value="@eq.Id">@eq.NombreEquipo</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <h1 class="text-danger fw-bold">VS</h1>
                    </div>
                    <div class="col-md-5">
                        <label class="text-info small fw-bold">VISITANTE</label>
                        <select name="Equipo2Id" class="form-select bg-black text-white border-secondary">
                            @foreach (var eq in Model)
                            {
                                <option value="@eq.Id">@eq.NombreEquipo</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mt-4">
                    <label class="text-info small fw-bold">SELECCIONA FECHA Y HORA</label>
                    <input type="datetime-local" name="FechaEncuentro"
                           class="form-control bg-black text-white border-secondary"
                           required />
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-warning w-100 fw-bold">AGENDAR ENCUENTRO</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">CANCELAR</a>
                </div>
            </form>
        </div>
    </div>
</div>