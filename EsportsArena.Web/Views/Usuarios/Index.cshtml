@model IEnumerable<EsportsArena.Entities.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container-fluid animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold mb-0">USUARIOS REGISTRADOS</h2>
            <p class="text-muted">Lista detallada de capitanes y miembros de la arena.</p>
        </div>
        <a asp-action="Registro" asp-controller="Login" class="btn btn-outline-primary fw-bold">
            <i class="bi bi-person-plus-fill"></i> NUEVO REGISTRO
        </a>
    </div>

    <div class="card bg-dark border-0 shadow-lg" style="background-color: #161b22 !important;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0" style="border-color: #30363d;">
                    <thead class="bg-black">
                        <tr>
                            <th class="ps-4 py-3 text-info">ID</th>
                            <th class="py-3 text-info">USERNAME</th>
                            <th class="py-3 text-info">EMAIL</th>
                            <th class="py-3 text-info">ESTADO</th>
                            <th class="py-3 text-info text-center">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr style="vertical-align: middle;">
                                <td class="ps-4">#@user.Id</td>
                                <td class="fw-bold">@user.Username</td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="badge bg-success-subtle text-success border border-success">
                                        <i class="bi bi-shield-check"></i> Encriptado
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-warning mx-1"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-outline-danger mx-1"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(0, 212, 255, 0.05) !important;
        transition: 0.3s;
    }

    .badge {
        font-size: 0.75rem;
        letter-spacing: 1px;
    }
</style>