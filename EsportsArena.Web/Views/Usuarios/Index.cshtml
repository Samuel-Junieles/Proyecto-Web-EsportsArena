@model IEnumerable<EsportsArena.Entities.Models.Usuario>

<div class="container-fluid animate__animated animate__fadeIn">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="display-6 fw-bold text-white">GESTIÓN DE <span style="color: var(--accent-cyan)">OPERADORES</span></h2>
            <p style="color: #a0aec0;">Administración central de cuentas de la Arena.</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Login/Registro" class="btn btn-neu text-info fw-bold py-2 px-4">
                <i class="bi bi-person-plus-fill me-2"></i>NUEVO REGISTRO
            </a>
        </div>
    </div>

    <div class="neu-card p-0">
        <table class="table table-dark align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4 py-3">ID</th>
                    <th class="py-3">USUARIO</th>
                    <th class="py-3">EMAIL</th>
                    <th class="py-3 text-center">ACCIONES</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4 text-muted">#@user.Id</td>
                        <td class="fw-bold text-white">@user.Username</td>
                        <td style="color: #cbd5e0;">@user.Email</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-3">
                                <button onclick="prepararEdicion(@user.Id)" class="btn-action edit"><i class="bi bi-pencil-fill"></i></button>
                                <button onclick="confirmarEliminacion(@user.Id)" class="btn-action delete"><i class="bi bi-trash3-fill"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function confirmarEliminacion(id) {
        Swal.fire({
            title: '¿ELIMINAR ACCESO?',
            text: "El usuario perderá sus privilegios inmediatamente.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ff4d4d',
            cancelButtonColor: '#1b222c',
            confirmButtonText: 'SÍ, ELIMINAR',
            background: '#12171e',
            color: '#fff'
        }).then((result) => {
            if (result.isConfirmed) {
                // Llamada AJAX para simular lo que hará Postman después
                fetch(`/Usuarios/Eliminar/${id}`, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if(data.success) {
                        Swal.fire('LOGRADO', data.message, 'success');
                        location.reload();
                    }
                });
            }
        });
    }
</script>